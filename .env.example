# Environment variables for Overmind
# Copy this file to .env and fill in your values

# Path to configuration file (optional)
# OVERMIND_CONFIG=/etc/overmind/overmind.conf

# Weather API key (overrides config file)
# WEATHER_API_KEY=your_api_key_here

# Wattrouter connection settings (override config file)
# WATTROUTER_URL=http://192.168.1.100
# WATTROUTER_USERNAME=admin
# WATTROUTER_PASSWORD=your_password_here
